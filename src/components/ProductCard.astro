---
export interface Props {
  id: string;
  name: string;
  description: string;
  price: number;
  category: string;
  stock: number;
  image_url?: string;
  href?: string;
}

const {
  id,
  name,
  description,
  price,
  category,
  stock,
  image_url,
  href = `/products/${id}`
} = Astro.props;

const inStock = stock > 0;
const shortDescription = description && description.length > 84
  ? `${description.slice(0, 84)}...`
  : description;
---

<a href={href} class="product-card" data-animate="fade-in-scale">
  <div class="product-media">
    {image_url ? (
      <img src={image_url} alt={name} class="product-image" loading="lazy" />
    ) : (
      <div class="product-image-placeholder" aria-hidden="true">
        <svg viewBox="0 0 24 24">
          <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
          <path d="m3.3 7 8.7 5 8.7-5"></path>
          <path d="M12 22V12"></path>
        </svg>
      </div>
    )}
    <span class={`stock-pill ${inStock ? 'is-in' : 'is-out'}`}>
      {inStock ? `${stock} en stock` : 'Agotado'}
    </span>
  </div>
  <div class="product-body">
    <p class="product-category">{category}</p>
    <h3 class="product-name">{name}</h3>
    <p class="product-description">{shortDescription}</p>
    <div class="product-footer">
      <p class="product-price">${price.toLocaleString('es-CO')}</p>
      <span class="product-link">Ver detalle</span>
    </div>
  </div>
</a>

<style>
  .product-card {
    display: flex;
    height: 100%;
    min-height: 430px;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.025));
    color: inherit;
    box-shadow: 0 12px 42px rgba(0, 0, 0, 0.22);
    transition: transform 0.32s var(--easing), border-color 0.32s var(--easing), box-shadow 0.32s var(--easing);
  }

  .product-card:hover {
    border-color: var(--cyan);
    transform: translateY(-8px);
    box-shadow: 0 0 0 1px rgba(0, 212, 255, 0.46), 0 0 28px rgba(0, 212, 255, 0.26), 0 24px 60px rgba(0, 0, 0, 0.34);
  }

  .product-media {
    position: relative;
    aspect-ratio: 1 / 1;
    flex: 0 0 auto;
    overflow: hidden;
    background: linear-gradient(135deg, rgba(0, 212, 255, 0.10), rgba(255, 79, 216, 0.08));
  }

  .product-image,
  .product-image-placeholder {
    width: 100%;
    height: 100%;
  }

  .product-image {
    object-fit: cover;
    transition: transform 0.5s var(--easing);
  }

  .product-card:hover .product-image {
    transform: scale(1.06);
  }

  .product-image-placeholder {
    display: grid;
    place-items: center;
  }

  .product-image-placeholder svg {
    width: 64px;
    height: 64px;
    fill: none;
    stroke: rgba(255, 255, 255, 0.38);
    stroke-width: 1.4;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .stock-pill {
    position: absolute;
    right: 0.85rem;
    bottom: 0.85rem;
    padding: 0.42rem 0.65rem;
    border: 1px solid currentColor;
    border-radius: 999px;
    background: rgba(7, 8, 13, 0.78);
    color: var(--green);
    font-size: 0.75rem;
    font-weight: 900;
    backdrop-filter: blur(8px);
  }

  .stock-pill.is-out {
    color: var(--red);
  }

  .product-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    padding: 1.05rem;
  }

  .product-category {
    margin-bottom: 0.5rem;
    color: var(--cyan);
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .product-name {
    min-height: 2.4em;
    margin-bottom: 0.55rem;
  }

  .product-description {
    display: -webkit-box;
    overflow: hidden;
    min-height: 3.9em;
    color: var(--text-muted);
    font-size: 0.92rem;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  @media (max-width: 560px) {
    .product-card {
      min-height: 0;
    }
  }

  .product-footer {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-top: auto;
    padding-top: 1rem;
  }

  .product-price {
    color: var(--text);
    font-size: 1.35rem;
    font-weight: 950;
  }

  .product-link {
    color: var(--cyan);
    font-size: 0.82rem;
    font-weight: 850;
    white-space: nowrap;
  }
</style>
