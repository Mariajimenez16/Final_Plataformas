---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#07080d" />
    <title>{title} | TechStore Admin</title>
  </head>
  <body>
    <header class="site-header admin-header">
      <nav class="site-nav">
        <a href="/admin" class="logo" aria-label="Ir al panel admin">
          <span class="logo-mark">AD</span>
          <span>Admin Studio</span>
        </a>
        <div class="nav-links">
          <a href="/admin">Dashboard</a>
          <a href="/admin/products">Productos</a>
          <a href="/">Tienda</a>
          <button id="logout-btn" class="secondary logout-btn">Salir</button>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <script>
      const logoutBtn = document.getElementById('logout-btn');
      logoutBtn?.addEventListener('click', async () => {
        try {
          const res = await fetch('/api/auth/logout', { method: 'POST' });
          if (res.ok) window.location.href = '/admin/auth/login';
        } catch (error) {
          console.error('Logout failed:', error);
        }
      });
    </script>

    <style>
      :global(main) {
        width: min(1420px, calc(100% - 2rem));
        margin: 0 auto;
        padding: 2rem 0 4rem;
      }

      .admin-header {
        background: rgba(7, 8, 13, 0.84);
      }

      .logout-btn {
        min-height: 40px;
        padding: 0.55rem 0.85rem;
      }
    </style>
  </body>
</html>
