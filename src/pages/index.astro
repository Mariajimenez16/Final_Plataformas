---
export const prerender = false;

import PublicLayout from '../layouts/PublicLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import { supabase } from '../lib/supabase';

const { url } = Astro;
const searchParams = url.searchParams;

const search = searchParams.get('search') || '';
const category = searchParams.get('category') || '';
const page = parseInt(searchParams.get('page') || '1');

const pageSize = 8;
const from = (page - 1) * pageSize;
const to = from + pageSize - 1;

let query = supabase
  .from('products')
  .select('*', { count: 'exact' })
  .range(from, to)
  .order('created_at', { ascending: false });

if (search) {
  query = query.ilike('name', `%${search}%`);
}

if (category) {
  query = query.eq('category', category);
}

const { data: products, error, count } = await query;
const totalPages = count ? Math.ceil(count / pageSize) : 1;

const { data: categoriesData } = await supabase
  .from('products')
  .select('category');

const categories = [
  ...new Set(categoriesData?.map((p) => p.category).filter(Boolean) || [])
];

const getPageUrl = (p: number) => {
  const newParams = new URLSearchParams(searchParams);
  newParams.set('page', p.toString());
  return `/?${newParams.toString()}`;
};
---

<PublicLayout title="Catalogo">
  <section class="hero-section">
    <div class="hero-copy" data-animate="fade-in">
      <p class="section-kicker">Catalogo </p>
      <h1>Gadgets que se sienten de otro nivel.</h1>
      <p class="hero-subtitle">
        Explora productos tecnologicos con una experiencia rapida, elegante y lista para comprar.
      </p>
      <div class="hero-actions">
        <a href="#catalogo" class="btn">Ver productos</a>
        <a href="/admin" class="btn secondary">Panel admin</a>
      </div>
    </div>
    <div class="hero-showcase" aria-hidden="true" data-animate="fade-in-scale">
      <div class="showcase-card card-main">
        <span>Good</span>
        <strong>Prices</strong>
      </div>
      <div class="showcase-card card-small">
        <span>Smart</span>
        <strong>Gadgets</strong>
      </div>
      <div class="showcase-ring"></div>
    </div>
  </section>

  <section id="catalogo" class="filters-section panel" data-animate="fade-in">
    <form method="GET" action="/" class="filters-form">
      <div class="filter-field search-field">
        <label for="search">Buscar</label>
        <input
          id="search"
          type="text"
          name="search"
          placeholder="Nombre del producto"
          value={search}
        />
      </div>

      <div class="filter-field">
        <label for="category">Categoria</label>
        <select id="category" name="category">
          <option value="">Todas</option>
          {categories.map((cat) => (
            <option value={cat} selected={category === cat}>{cat}</option>
          ))}
        </select>
      </div>

      <button type="submit" class="btn-search">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
        Buscar
      </button>
    </form>
  </section>

  {error ? (
    <div class="error-container">
      <p>Error al cargar productos.</p>
    </div>
  ) : (
    <section class="products-grid" aria-label="Productos">
      {products && products.length > 0 ? (
        products.map((product) => (
          <ProductCard
            id={product.id}
            name={product.name}
            description={product.description}
            price={product.price}
            category={product.category}
            stock={product.stock}
            image_url={product.image_url}
          />
        ))
      ) : (
        <div class="empty-state">
          <p>No hay productos disponibles con estos filtros.</p>
        </div>
      )}
    </section>
  )}

  {totalPages > 1 && (
    <nav class="pagination" aria-label="Paginacion">
      <a
        href={page > 1 ? getPageUrl(page - 1) : '#'}
        class={`btn secondary ${page === 1 ? 'disabled' : ''}`}
      >
        Anterior
      </a>
      <span class="page-info">Pagina {page} de {totalPages}</span>
      <a
        href={page < totalPages ? getPageUrl(page + 1) : '#'}
        class={`btn secondary ${page === totalPages ? 'disabled' : ''}`}
      >
        Siguiente
      </a>
    </nav>
  )}
</PublicLayout>

<style>
  .hero-section {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(340px, 0.95fr);
    gap: clamp(2rem, 5vw, 5rem);
    min-height: min(680px, calc(100vh - 112px));
    align-items: center;
    padding: 2rem 0 3rem;
  }

  .hero-copy {
    max-width: 760px;
  }

  .hero-copy h1 {
    max-width: 820px;
  }

  .hero-subtitle {
    max-width: 620px;
    margin-top: 1.25rem;
    color: var(--text-soft);
    font-size: clamp(1rem, 2vw, 1.22rem);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 2rem;
  }

  .hero-showcase {
    position: relative;
    min-height: 430px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    background:
      linear-gradient(140deg, rgba(0, 212, 255, 0.20), transparent 38%),
      linear-gradient(320deg, rgba(255, 79, 216, 0.16), transparent 40%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.02));
    box-shadow: var(--shadow);
  }

  .hero-showcase::before {
    content: "";
    position: absolute;
    inset: 15%;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 50%;
    transform: rotateX(64deg) rotateZ(-18deg);
  }

  .hero-showcase::after {
    content: "";
    position: absolute;
    inset: 0;
    background-image: linear-gradient(rgba(255, 255, 255, 0.08) 1px, transparent 1px);
    background-size: 100% 28px;
    opacity: 0.22;
  }

  .showcase-card {
    position: absolute;
    z-index: 1;
    display: grid;
    gap: 0.25rem;
    width: 190px;
    padding: 1rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: rgba(7, 8, 13, 0.72);
    backdrop-filter: blur(12px);
  }

  .showcase-card span {
    color: var(--cyan);
    font-size: 2.2rem;
    font-weight: 950;
    line-height: 1;
  }

  .showcase-card strong {
    color: var(--text);
  }

  .card-main {
    top: 26%;
    left: 14%;
  }

  .card-small {
    right: 11%;
    bottom: 18%;
  }

  .showcase-ring {
    position: absolute;
    right: 15%;
    top: 16%;
    width: 115px;
    height: 115px;
    border: 20px solid rgba(0, 212, 255, 0.18);
    border-top-color: rgba(255, 79, 216, 0.50);
    border-radius: 50%;
    filter: drop-shadow(0 0 22px rgba(0, 212, 255, 0.20));
  }

  .filters-section {
    margin-bottom: 1.35rem;
    padding: 1rem;
  }

  .filters-form {
    display: grid;
    grid-template-columns: minmax(220px, 1fr) minmax(180px, 260px) auto;
    gap: 0.9rem;
    align-items: end;
  }

  .btn-search svg {
    width: 18px;
    height: 18px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2.2;
    stroke-linecap: round;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.1rem;
    align-items: stretch;
  }

  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: 2rem;
  }

  .page-info {
    color: var(--text-muted);
    font-weight: 800;
  }

  @media (max-width: 920px) {
    .hero-section {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .hero-showcase {
      min-height: 330px;
    }

    .filters-form {
      grid-template-columns: 1fr;
    }

    .products-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .products-grid {
      grid-template-columns: 1fr;
    }

    .hero-actions .btn,
    .pagination .btn {
      width: 100%;
    }

    .pagination {
      flex-direction: column;
    }
  }
</style>
