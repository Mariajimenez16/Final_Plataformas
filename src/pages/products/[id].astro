---
export const prerender = false;

import PublicLayout from '../../layouts/PublicLayout.astro';
import { supabase } from '../../lib/supabase';

const { id } = Astro.params;

const { data: product, error } = await supabase
  .from('products')
  .select('*')
  .eq('id', id)
  .single();

if (error || !product) {
  return Astro.redirect('/');
}
---

<PublicLayout title={product.name}>
  <div class="product-detail-container" data-animate="fade-in">
    <a href="/" class="back-link">← Volver al catálogo</a>

    <div class="product-detail-grid">
      <section class="product-image-section">
        <div class="image-wrapper">
          {product.image_url ? (
            <img src={product.image_url} alt={product.name} class="product-image" />
          ) : (
            <div class="product-image-placeholder">📦</div>
          )}
        </div>
      </section>

      <section class="product-info-section" data-animate="fade-in-scale">
        <div class="breadcrumb">
          <a href="/?category={product.category}">{product.category}</a>
        </div>

        <h1>{product.name}</h1>

        <div class="stock-status">
          {product.stock > 0 ? (
            <span class="in-stock">✓ {product.stock} en stock</span>
          ) : (
            <span class="out-of-stock">✗ Agotado</span>
          )}
        </div>

        <div class="divider-3d"></div>

        <p class="product-description">{product.description}</p>

        <div class="price-section">
          <p class="price-label">Precio</p>
          <p class="price">${product.price.toLocaleString('es-CO')}</p>
        </div>

        <div class="actions-section">
          <button
            id="add-to-cart-btn"
            class={`btn btn-primary ${product.stock === 0 ? 'disabled' : ''}`}
            disabled={product.stock === 0}
          >
            {product.stock > 0 ? '🛒 Agregar al carrito' : 'Agotado'}
          </button>
          <a href="/" class="btn btn-secondary">Seguir comprando</a>
        </div>

        <div class="specs-section">
          <h3>Detalles del producto</h3>
          <div class="specs-grid">
            <div class="spec">
              <span class="spec-label">ID</span>
              <span class="spec-value">{product.id}</span>
            </div>
            <div class="spec">
              <span class="spec-label">Categoría</span>
              <span class="spec-value">{product.category}</span>
            </div>
            <div class="spec">
              <span class="spec-label">Stock disponible</span>
              <span class="spec-value">{product.stock} unidades</span>
            </div>
            <div class="spec">
              <span class="spec-label">Estado</span>
              <span class="spec-value">
                {product.stock > 0 ? 'En stock' : 'Agotado'}
              </span>
            </div>
          </div>
        </div>
      </section>
  <script define:vars={{ product }}>
    const addToCartBtn = document.getElementById('add-to-cart-btn');
    if (addToCartBtn) {
      addToCartBtn.addEventListener('click', () => {
        if (window.addToCart) {
          window.addToCart({
            id: product.id,
            name: product.name,
            price: product.price,
            image_url: product.image_url
          });
        } else {
          console.error('addToCart function is not globally defined');
        }
      });
    }
  </script>
</PublicLayout>

<style>
  .product-detail-container {
    animation: fadeInUp 0.6s var(--easing-sharp);
  }

  .back-link {
    display: inline-block;
    margin-bottom: 2rem;
    color: var(--accent-cyan);
    text-decoration: none;
    font-weight: 600;
    transition: color 0.3s ease;
  }

  .back-link:hover {
    color: var(--accent-magenta);
  }

  .product-detail-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
    margin-top: 2rem;
  }

  .product-image-section {
    position: sticky;
    top: 100px;
  }

  .image-wrapper {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 20px 60px rgba(0, 212, 255, 0.1);
    transition: all 0.4s var(--easing-sharp);
  }

  .image-wrapper:hover {
    border-color: var(--accent-cyan);
    box-shadow: 0 30px 80px rgba(0, 212, 255, 0.2);
    transform: perspective(1000px) rotateX(2deg) rotateY(-2deg);
  }

  .product-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s var(--easing-sharp);
  }

  .image-wrapper:hover .product-image {
    transform: scale(1.05);
  }

  .product-image-placeholder {
    font-size: 5rem;
  }

  .breadcrumb {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }

  .breadcrumb a {
    color: var(--accent-cyan);
    text-decoration: none;
  }

  .product-info-section h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .stock-status {
    margin-bottom: 1.5rem;
  }

  .in-stock {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: rgba(0, 212, 255, 0.1);
    color: var(--accent-cyan);
    border-radius: 6px;
    font-weight: 600;
  }

  .out-of-stock {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: rgba(255, 68, 68, 0.1);
    color: #ff4444;
    border-radius: 6px;
    font-weight: 600;
  }

  .product-description {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--text-secondary);
    margin-bottom: 2rem;
  }

  .price-section {
    margin-bottom: 2rem;
    padding: 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 8px;
  }

  .price-label {
    color: var(--text-muted);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 0.5rem;
  }

  .price {
    font-size: 2.5rem;
    font-weight: 900;
    color: var(--accent-cyan);
  }

  .actions-section {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .btn {
    flex: 1;
    min-width: 150px;
    padding: 1rem;
    border-radius: 8px;
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s var(--easing-sharp);
    border: none;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--accent-cyan), var(--accent-magenta));
    color: var(--bg-dark);
  }

  .btn-primary:hover:not(.disabled) {
    transform: translateY(-2px);
    box-shadow: 0 15px 35px rgba(0, 212, 255, 0.4);
  }

  .btn-primary.disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .btn-secondary {
    background: transparent;
    color: var(--accent-cyan);
    border: 2px solid var(--accent-cyan);
  }

  .btn-secondary:hover {
    background: var(--accent-cyan);
    color: var(--bg-dark);
  }

  .specs-section {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 1.5rem;
  }

  .specs-section h3 {
    margin-bottom: 1.5rem;
    color: var(--accent-cyan);
  }

  .specs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 1rem;
  }

  .spec {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .spec-label {
    font-size: 0.85rem;
    text-transform: uppercase;
    color: var(--text-muted);
    letter-spacing: 1px;
    font-weight: 600;
  }

  .spec-value {
    font-size: 0.95rem;
    color: var(--text-primary);
  }

  @media (max-width: 1024px) {
    .product-detail-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .product-image-section {
      position: static;
    }
  }

  @media (max-width: 600px) {
    .product-info-section h1 {
      font-size: 1.8rem;
    }

    .price {
      font-size: 2rem;
    }

    .actions-section {
      flex-direction: column;
    }

    .btn {
      width: 100%;
    }

    .specs-grid {
      grid-template-columns: 1fr;
    }
  }
</style>