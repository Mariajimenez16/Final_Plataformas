---
export const prerender = false;

import PublicLayout from '../../layouts/PublicLayout.astro';
import { supabase } from '../../lib/supabase';

const { id } = Astro.params;

const { data: product, error } = await supabase
  .from('products')
  .select('*')
  .eq('id', id)
  .single();

if (error || !product) {
  return Astro.redirect('/');
}
---

<PublicLayout title={product.name}>
  <article class="product-detail-container" data-animate="fade-in">
    <a href="/" class="back-link">Volver al catalogo</a>

    <div class="product-detail-grid">
      <section class="product-image-section">
        <div class="image-wrapper">
          {product.image_url ? (
            <img src={product.image_url} alt={product.name} class="detail-image" />
          ) : (
            <div class="product-image-placeholder" aria-hidden="true">
              <svg viewBox="0 0 24 24">
                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                <path d="m3.3 7 8.7 5 8.7-5"></path>
                <path d="M12 22V12"></path>
              </svg>
            </div>
          )}
        </div>
      </section>

      <section class="product-info-section" data-animate="fade-in-scale">
        <p class="section-kicker">{product.category}</p>
        <h1>{product.name}</h1>

        <div class={`stock-status ${product.stock > 0 ? 'in-stock' : 'out-of-stock'}`}>
          {product.stock > 0 ? `${product.stock} unidades disponibles` : 'Agotado'}
        </div>

        <p class="product-description">{product.description}</p>

        <div class="price-panel panel">
          <span>Precio</span>
          <strong>${product.price.toLocaleString('es-CO')}</strong>
        </div>

        <div class="actions-section">
          <button
            id="add-to-cart-btn"
            class={product.stock === 0 ? 'disabled' : ''}
            disabled={product.stock === 0}
          >
            {product.stock > 0 ? 'Agregar al carrito' : 'Agotado'}
          </button>
          <a href="/" class="btn secondary">Seguir comprando</a>
        </div>

        <div class="specs-section panel">
          <h2>Detalles</h2>
          <div class="specs-grid">
            <div class="spec">
              <span>Categoria</span>
              <strong>{product.category}</strong>
            </div>
            <div class="spec">
              <span>Stock</span>
              <strong>{product.stock}</strong>
            </div>
            <div class="spec">
              <span>Estado</span>
              <strong>{product.stock > 0 ? 'Disponible' : 'Agotado'}</strong>
            </div>
          </div>
        </div>
      </section>
    </div>
  </article>

  <script define:vars={{ product }}>
    const addToCartBtn = document.getElementById('add-to-cart-btn');
    addToCartBtn?.addEventListener('click', () => {
      if (window.addToCart) {
        window.addToCart({
          id: product.id,
          name: product.name,
          price: product.price,
          image_url: product.image_url
        });
      }
    });
  </script>
</PublicLayout>

<style>
  .product-detail-container {
    animation: fadeInUp 0.6s var(--easing) both;
  }

  .back-link {
    display: inline-flex;
    margin-bottom: 1.4rem;
    color: var(--cyan);
    font-weight: 850;
  }

  .back-link::before {
    content: "<";
    margin-right: 0.5rem;
  }

  .product-detail-grid {
    display: grid;
    grid-template-columns: minmax(320px, 0.95fr) minmax(0, 1.05fr);
    gap: clamp(1.5rem, 5vw, 4rem);
    align-items: start;
  }

  .product-image-section {
    position: sticky;
    top: 96px;
  }

  .image-wrapper {
    display: grid;
    overflow: hidden;
    aspect-ratio: 1;
    place-items: center;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: linear-gradient(135deg, rgba(0, 212, 255, 0.11), rgba(255, 79, 216, 0.08));
    box-shadow: var(--shadow);
  }

  .detail-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-image-placeholder svg {
    width: 96px;
    height: 96px;
    fill: none;
    stroke: rgba(255, 255, 255, 0.42);
    stroke-width: 1.4;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .product-info-section h1 {
    margin-bottom: 1rem;
  }

  .stock-status {
    display: inline-flex;
    margin-bottom: 1.5rem;
    padding: 0.48rem 0.72rem;
    border: 1px solid currentColor;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    font-weight: 900;
  }

  .in-stock {
    color: var(--green);
  }

  .out-of-stock {
    color: var(--red);
  }

  .product-description {
    max-width: 760px;
    margin-bottom: 1.5rem;
    color: var(--text-soft);
    font-size: 1.08rem;
  }

  .price-panel {
    display: grid;
    gap: 0.35rem;
    margin-bottom: 1rem;
    padding: 1.2rem;
  }

  .price-panel span {
    color: var(--text-muted);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .price-panel strong {
    color: var(--text);
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1;
  }

  .actions-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.8rem;
    margin-bottom: 1rem;
  }

  .specs-section {
    padding: 1.2rem;
  }

  .specs-section h2 {
    margin-bottom: 1rem;
    font-size: 1.2rem;
  }

  .specs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }

  .spec {
    display: grid;
    gap: 0.25rem;
    padding: 0.8rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.03);
  }

  .spec span {
    color: var(--text-muted);
    font-size: 0.76rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .spec strong {
    color: var(--text);
  }

  @media (max-width: 900px) {
    .product-detail-grid {
      grid-template-columns: 1fr;
    }

    .product-image-section {
      position: static;
    }
  }

  @media (max-width: 560px) {
    .actions-section,
    .specs-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
