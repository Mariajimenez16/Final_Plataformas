---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Dashboard Admin">
  <div class="dashboard-container" data-animate="fade-in">
    <section class="header-section">
      <h1>Dashboard <span>Admin</span></h1>
      <p class="subtitle">Bienvenido. Gestiona el catálogo de productos</p>
    </section>

    <div class="divider-3d"></div>

    <section class="stats-grid">
      <div class="stat-card" data-animate="fade-in-scale">
        <div class="stat-number" id="product-count">0</div>
        <p class="stat-label">Productos</p>
      </div>

      <div class="stat-card" data-animate="fade-in-scale">
        <div class="stat-number" id="stock-count">0</div>
        <p class="stat-label">Total Stock</p>
      </div>

      <div class="stat-card" data-animate="fade-in-scale">
        <div class="stat-number" id="category-count">0</div>
        <p class="stat-label">Categorías</p>
      </div>

      <div class="stat-card" data-animate="fade-in-scale">
        <div class="stat-number" id="revenue-count">0</div>
        <p class="stat-label">Valor Total</p>
      </div>
    </section>

    <div class="divider-3d" style="margin-top: 3rem;"></div>

    <section class="actions-section">
      <h2>Acciones Rápidas</h2>
      <div class="action-buttons">
        <a href="/admin/products/new" class="btn btn-primary">
          ➕ Crear Producto
        </a>
        <a href="/admin/products" class="btn btn-secondary">
          📋 Ver Todos
        </a>
      </div>
    </section>

    <section class="recent-products-section" style="margin-top: 3rem;">
      <h2>Productos Recientes</h2>
      <div id="recent-products" class="products-list">
        <p style="color: var(--text-muted); text-align: center; padding: 2rem;">
          Cargando productos...
        </p>
      </div>
    </section>
  </div>
</AdminLayout>

<script>
  async function loadDashboardData() {
    try {
      const response = await fetch('/api/products');
      const products = await response.json();

      if (!Array.isArray(products)) {
        console.error('Invalid products response');
        return;
      }

      // Calculate stats
      const totalProducts = products.length;
      const totalStock = products.reduce((sum, p) => sum + (p.stock || 0), 0);
      const categories = new Set(products.map((p) => p.category)).size;
      const totalValue = products.reduce((sum, p) => sum + (p.price * p.stock || 0), 0);

      document.getElementById('product-count')!.textContent = totalProducts.toString();
      document.getElementById('stock-count')!.textContent = totalStock.toString();
      document.getElementById('category-count')!.textContent = categories.toString();
      document.getElementById('revenue-count')!.textContent = `$${totalValue.toLocaleString('es-CO')}`;

      // Display recent products (first 5)
      const recentHTML = products.slice(0, 5).map((p) => `
        <div class="recent-product-item" data-animate="fade-in">
          <div class="recent-product-info">
            <h4>${p.name}</h4>
            <p style="color: var(--text-muted); font-size: 0.9rem;">
              ${p.category} • $${p.price.toLocaleString('es-CO')} • ${p.stock} stock
            </p>
          </div>
          <div class="recent-product-actions">
            <a href="/admin/products/edit?id=${p.id}" class="btn btn-small">Editar</a>
          </div>
        </div>
      `).join('');

      const recentDiv = document.getElementById('recent-products')!;
      recentDiv.innerHTML = recentHTML || '<p style="text-align: center; color: var(--text-muted);">No hay productos</p>';
    } catch (error) {
      console.error('Failed to load dashboard:', error);
      document.getElementById('recent-products')!.innerHTML = '<p style="color: #ff4444;">Error al cargar datos</p>';
    }
  }

  loadDashboardData();
</script>

<style>
  .dashboard-container {
    animation: fadeInUp 0.6s var(--easing-sharp);
  }

  .header-section h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .header-section h1 span {
    color: var(--accent-cyan);
  }

  .subtitle {
    color: var(--text-muted);
    font-size: 1.1rem;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
    margin: 2rem 0;
  }

  .stat-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 2rem;
    text-align: center;
    transition: all 0.4s var(--easing-sharp);
    position: relative;
    overflow: hidden;
  }

  .stat-card::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(0, 212, 255, 0.1) 0%, transparent 70%);
    transition: all 0.4s ease;
  }

  .stat-card:hover {
    transform: perspective(1000px) rotateX(3deg) translateY(-5px);
    border-color: var(--accent-cyan);
    box-shadow: 0 15px 40px rgba(0, 212, 255, 0.2);
  }

  .stat-card:hover::before {
    top: -25%;
    right: -25%;
  }

  .stat-number {
    font-size: 2.5rem;
    font-weight: 900;
    color: var(--accent-cyan);
    margin-bottom: 0.5rem;
    position: relative;
    z-index: 1;
  }

  .stat-label {
    color: var(--text-muted);
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    position: relative;
    z-index: 1;
  }

  .actions-section {
    margin: 2rem 0;
  }

  .actions-section h2 {
    margin-bottom: 1.5rem;
  }

  .action-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.85rem 1.5rem;
    border-radius: 8px;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.3s var(--easing-sharp);
    cursor: pointer;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--accent-cyan), var(--accent-magenta));
    color: var(--bg-dark);
    border: none;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(0, 212, 255, 0.4);
  }

  .btn-secondary {
    background: transparent;
    color: var(--accent-cyan);
    border: 2px solid var(--accent-cyan);
  }

  .btn-secondary:hover {
    background: var(--accent-cyan);
    color: var(--bg-dark);
  }

  .btn-small {
    padding: 0.5rem 1rem;
    font-size: 0.85rem;
    background: var(--accent-cyan);
    color: var(--bg-dark);
    border: none;
  }

  .recent-products-section {
    margin-top: 3rem;
  }

  .recent-products-section h2 {
    margin-bottom: 1.5rem;
  }

  .products-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .recent-product-item {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: all 0.3s ease;
  }

  .recent-product-item:hover {
    border-color: var(--accent-cyan);
    box-shadow: 0 5px 15px rgba(0, 212, 255, 0.15);
    transform: translateX(5px);
  }

  .recent-product-info h4 {
    margin-bottom: 0.5rem;
  }

  .recent-product-actions {
    display: flex;
    gap: 0.5rem;
  }

  @media (max-width: 768px) {
    .header-section h1 {
      font-size: 1.8rem;
    }

    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .recent-product-item {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }

    .recent-product-actions {
      width: 100%;
    }

    .recent-product-actions .btn {
      width: 100%;
    }
  }
</style>
