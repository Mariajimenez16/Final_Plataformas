---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Dashboard Admin">
  <div class="dashboard-container" data-animate="fade-in">
    <section class="dashboard-hero">
      <div>
        <p class="section-kicker">Centro de control</p>
        <h1>Dashboard admin</h1>
        <p class="subtitle">Gestiona catalogo, inventario y valor de productos desde una vista clara.</p>
      </div>
      <div class="hero-actions">
        <a href="/admin/products/new" class="btn">Crear producto</a>
        <a href="/admin/products" class="btn secondary">Ver inventario</a>
      </div>
    </section>

    <section class="stats-grid">
      <article class="stat-card">
        <span class="stat-number" id="product-count">0</span>
        <p>Productos</p>
      </article>
      <article class="stat-card">
        <span class="stat-number" id="stock-count">0</span>
        <p>Total stock</p>
      </article>
      <article class="stat-card">
        <span class="stat-number" id="category-count">0</span>
        <p>Categorias</p>
      </article>
      <article class="stat-card">
        <span class="stat-number" id="revenue-count">0</span>
        <p>Valor total</p>
      </article>
    </section>

    <section class="recent-products-section panel">
      <div class="section-heading">
        <div>
          <p class="section-kicker">Ultimos productos</p>
          <h2>Recientes</h2>
        </div>
        <a href="/admin/products" class="btn secondary">Gestionar todos</a>
      </div>
      <div id="recent-products" class="products-list">
        <p class="loading-text">Cargando productos...</p>
      </div>
    </section>
  </div>
</AdminLayout>

<script>
  function escapeHTML(value: unknown) {
    return String(value ?? '').replace(/[&<>"']/g, (char) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#039;'
    }[char] || char));
  }

  async function loadDashboardData() {
    const recentDiv = document.getElementById('recent-products');
    try {
      const response = await fetch('/api/products');
      const products = await response.json();

      if (!Array.isArray(products)) return;

      const totalProducts = products.length;
      const totalStock = products.reduce((sum, p) => sum + (Number(p.stock) || 0), 0);
      const categories = new Set(products.map((p) => p.category).filter(Boolean)).size;
      const totalValue = products.reduce((sum, p) => sum + ((Number(p.price) || 0) * (Number(p.stock) || 0)), 0);

      document.getElementById('product-count')!.textContent = totalProducts.toString();
      document.getElementById('stock-count')!.textContent = totalStock.toString();
      document.getElementById('category-count')!.textContent = categories.toString();
      document.getElementById('revenue-count')!.textContent = `$${totalValue.toLocaleString('es-CO')}`;

      if (!recentDiv) return;
      recentDiv.innerHTML = products.slice(0, 4).map((p) => `
        <article class="recent-product-item">
          <img src="${escapeHTML(p.image_url || 'https://images.unsplash.com/photo-1516321318423-f06f85e504b3?w=160&auto=format&fit=crop')}" alt="${escapeHTML(p.name)}" />
          <div class="recent-product-info">
            <h3>${escapeHTML(p.name)}</h3>
            <p>${escapeHTML(p.category)}</p>
            <strong>$${Number(p.price || 0).toLocaleString('es-CO')}</strong>
            <span>${Number(p.stock || 0)} en stock</span>
          </div>
          <a href="/admin/products/edit?id=${encodeURIComponent(p.id)}" class="btn secondary">Editar</a>
        </article>
      `).join('') || '<p class="loading-text">No hay productos.</p>';
    } catch (error) {
      console.error('Failed to load dashboard:', error);
      if (recentDiv) recentDiv.innerHTML = '<p class="error-text">Error al cargar datos.</p>';
    }
  }

  loadDashboardData();
</script>

<style is:global>
  .dashboard-container {
    animation: fadeInUp 0.6s var(--easing) both;
  }

  .dashboard-hero {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.5rem 0 1rem;
  }

  .subtitle {
    max-width: 620px;
    margin-top: 0.85rem;
    color: var(--text-muted);
    font-size: 1.05rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin: 1.25rem 0;
  }

  .stat-card {
    overflow: hidden;
    position: relative;
    padding: 1.2rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.055), rgba(255, 255, 255, 0.025));
    box-shadow: 0 12px 42px rgba(0, 0, 0, 0.18);
  }

  .stat-card::after {
    content: "";
    position: absolute;
    right: -28px;
    bottom: -28px;
    width: 96px;
    height: 96px;
    border: 18px solid rgba(0, 212, 255, 0.12);
    border-radius: 50%;
  }

  .stat-number {
    display: block;
    color: var(--cyan);
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 950;
    line-height: 1;
  }

  .stat-card p {
    margin-top: 0.55rem;
    color: var(--text-muted);
    font-weight: 850;
    text-transform: uppercase;
  }

  .recent-products-section {
    padding: 1rem;
  }

  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .products-list {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .recent-product-item {
    display: flex;
    min-height: 100%;
    overflow: hidden;
    flex-direction: column;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.055), rgba(255, 255, 255, 0.025));
    transition: transform 0.28s var(--easing), border-color 0.28s var(--easing), box-shadow 0.28s var(--easing);
  }

  .recent-product-item:hover {
    border-color: var(--cyan);
    transform: translateY(-6px);
    box-shadow: 0 0 0 1px rgba(0, 212, 255, 0.42), 0 18px 46px rgba(0, 212, 255, 0.18);
  }

  .recent-product-item img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
  }

  .recent-product-info {
    display: flex;
    flex: 1;
    flex-direction: column;
    min-width: 0;
    padding: 0.85rem;
  }

  .recent-product-info h3 {
    min-height: 2.4em;
    overflow: hidden;
    display: -webkit-box;
    line-height: 1.2;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .recent-product-info p,
  .loading-text {
    color: var(--text-muted);
  }

  .recent-product-info strong {
    display: block;
    margin-top: 0.5rem;
    color: var(--text);
    font-size: 1.1rem;
    font-weight: 950;
  }

  .recent-product-info span {
    color: var(--cyan);
    font-size: 0.82rem;
    font-weight: 850;
  }

  .recent-product-item .btn {
    width: calc(100% - 1.7rem);
    margin: 0 0.85rem 0.85rem;
  }

  .error-text {
    color: var(--red);
  }

  @media (max-width: 900px) {
    .dashboard-hero,
    .section-heading {
      align-items: stretch;
      flex-direction: column;
    }

    .stats-grid,
    .products-list {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .stats-grid,
    .products-list {
      grid-template-columns: 1fr;
    }

    .hero-actions .btn,
    .section-heading .btn,
    .recent-product-item .btn {
      width: 100%;
    }
  }
</style>
