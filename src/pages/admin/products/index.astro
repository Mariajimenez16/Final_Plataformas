---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Gestionar Productos">
  <div class="products-admin-container">
    <section class="page-hero" data-animate="fade-in">
      <div>
        <p class="section-kicker">Inventario visual</p>
        <h1>Gestionar productos</h1>
        <p class="page-subtitle">
          Edita precios, stock e imagenes desde tarjetas claras, igual de visuales que el catalogo de cliente.
        </p>
      </div>
      <a href="/admin/products/new" class="btn add-btn">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 5v14"></path>
          <path d="M5 12h14"></path>
        </svg>
        Nuevo producto
      </a>
    </section>

    <section class="toolbar panel" data-animate="fade-in">
      <div class="toolbar-stat">
        <span id="product-total">0</span>
        <small>productos cargados</small>
      </div>
      <div class="toolbar-copy">
        <strong>Modo administrador</strong>
        <p>Las acciones aparecen siempre en cada tarjeta para editar o eliminar sin perder contexto.</p>
      </div>
    </section>

    <section id="products-container" class="products-grid-admin" aria-label="Productos administrables">
      <div class="loading-skeleton">
        <div class="skeleton-card"></div>
        <div class="skeleton-card"></div>
        <div class="skeleton-card"></div>
      </div>
    </section>
  </div>
</AdminLayout>

<script>
  function escapeHTML(value: unknown) {
    return String(value ?? '').replace(/[&<>"']/g, (char) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#039;'
    }[char] || char));
  }

  async function loadProducts() {
    const container = document.getElementById('products-container');
    const total = document.getElementById('product-total');
    if (!container) return;

    try {
      const response = await fetch('/api/products');
      const products = await response.json();

      if (!Array.isArray(products) || products.length === 0) {
        if (total) total.textContent = '0';
        container.innerHTML = `
          <div class="empty-state admin-empty">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
              <path d="M3.3 7 12 12l8.7-5"></path>
              <path d="M12 22V12"></path>
            </svg>
            <p>No hay productos en el catalogo todavia.</p>
            <a href="/admin/products/new" class="btn">Agregar primer producto</a>
          </div>
        `;
        return;
      }

      if (total) total.textContent = products.length.toString();

      container.innerHTML = products.map((p, i) => {
        const name = escapeHTML(p.name);
        const category = escapeHTML(p.category || 'Sin categoria');
        const description = escapeHTML(p.description ? `${p.description.slice(0, 92)}${p.description.length > 92 ? '...' : ''}` : 'Sin descripcion');
        const price = Number(p.price || 0).toLocaleString('es-CO');
        const stock = Number(p.stock || 0);
        const stockClass = stock > 0 ? 'is-in' : 'is-out';
        const stockText = stock > 0 ? `${stock} en stock` : 'Agotado';
        const image = escapeHTML(p.image_url || '');
        const id = encodeURIComponent(p.id);

        return `
          <article class="admin-product-card" style="animation-delay: ${i * 0.035}s">
            <div class="admin-product-media">
              ${image
                ? `<img src="${image}" alt="${name}" class="admin-product-img" onerror="this.style.display='none'; this.nextElementSibling.style.display='grid';" />`
                : ''
              }
              <div class="admin-product-placeholder" ${image ? 'style="display:none"' : ''}>
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <rect x="3" y="3" width="18" height="18" rx="2"></rect>
                  <circle cx="8.5" cy="8.5" r="1.5"></circle>
                  <path d="m21 15-5-5L5 21"></path>
                </svg>
              </div>
              <span class="stock-pill ${stockClass}">${stockText}</span>
            </div>

            <div class="admin-product-body">
              <p class="admin-product-category">${category}</p>
              <h3>${name}</h3>
              <p class="admin-product-description">${description}</p>

              <div class="admin-product-bottom">
                <strong>$${price}</strong>
              </div>

              <div class="admin-product-actions">
                <a href="/admin/products/edit?id=${id}" class="btn secondary action-btn">
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M12 20h9"></path>
                    <path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"></path>
                  </svg>
                  Editar
                </a>
                <button class="btn danger action-btn delete-btn" data-id="${escapeHTML(p.id)}" data-name="${name}">
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M3 6h18"></path>
                    <path d="M8 6V4h8v2"></path>
                    <path d="M19 6 18 20H6L5 6"></path>
                  </svg>
                  Eliminar
                </button>
              </div>
            </div>
          </article>
        `;
      }).join('');

      document.querySelectorAll('.delete-btn').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const id = btn.getAttribute('data-id');
          const name = btn.getAttribute('data-name');
          if (!id || !confirm(`Eliminar "${name}"?\n\nEsta accion no se puede deshacer.`)) return;

          btn.setAttribute('disabled', 'true');
          btn.textContent = 'Eliminando...';

          try {
            const response = await fetch(`/api/products/${encodeURIComponent(id)}`, { method: 'DELETE' });
            if (!response.ok) {
              alert('Error al eliminar el producto.');
              btn.removeAttribute('disabled');
              btn.textContent = 'Eliminar';
              return;
            }
            loadProducts();
          } catch (error) {
            alert('Error al conectar con el servidor.');
            btn.removeAttribute('disabled');
            btn.textContent = 'Eliminar';
          }
        });
      });
    } catch (error) {
      console.error('Failed to load products:', error);
      container.innerHTML = `
        <div class="empty-state error-state">
          <p>Error al cargar productos del servidor.</p>
        </div>
      `;
    }
  }

  loadProducts();
</script>

<style is:global>
  .products-admin-container {
    animation: fadeInUp 0.6s var(--easing) both;
  }

  .page-hero {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1.5rem;
    margin-bottom: 1rem;
    padding: 1.5rem 0 1rem;
  }

  .page-subtitle {
    max-width: 690px;
    margin-top: 0.9rem;
    color: var(--text-muted);
    font-size: 1.05rem;
  }

  .add-btn {
    flex-shrink: 0;
  }

  .add-btn svg,
  .action-btn svg {
    width: 18px;
    height: 18px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2.2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .toolbar {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.2rem;
    padding: 1rem;
  }

  .toolbar-stat {
    display: grid;
    min-width: 150px;
    padding-right: 1rem;
    border-right: 1px solid var(--line);
  }

  .toolbar-stat span {
    color: var(--cyan);
    font-size: 2rem;
    font-weight: 950;
    line-height: 1;
  }

  .toolbar-stat small,
  .toolbar-copy p {
    color: var(--text-muted);
  }

  .toolbar-copy strong {
    color: var(--text);
  }

  .products-grid-admin {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.1rem;
    align-items: stretch;
  }

  .admin-product-card {
    display: flex;
    height: 100%;
    min-height: 474px;
    overflow: hidden;
    flex-direction: column;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.055), rgba(255, 255, 255, 0.025));
    box-shadow: 0 12px 42px rgba(0, 0, 0, 0.22);
    animation: fadeInUp 0.42s var(--easing) both;
    transition: transform 0.28s var(--easing), border-color 0.28s var(--easing), box-shadow 0.28s var(--easing);
  }

  .admin-product-card:hover {
    border-color: var(--cyan);
    transform: translateY(-8px);
    box-shadow: 0 0 0 1px rgba(0, 212, 255, 0.46), 0 0 28px rgba(0, 212, 255, 0.26), 0 24px 60px rgba(0, 0, 0, 0.34);
  }

  .admin-product-media {
    position: relative;
    aspect-ratio: 1 / 1;
    flex: 0 0 auto;
    overflow: hidden;
    background: linear-gradient(135deg, rgba(0, 212, 255, 0.10), rgba(255, 79, 216, 0.08));
  }

  .admin-product-img,
  .admin-product-placeholder {
    width: 100%;
    height: 100%;
  }

  .admin-product-img {
    object-fit: cover;
    transition: transform 0.5s var(--easing);
  }

  .admin-product-card:hover .admin-product-img {
    transform: scale(1.06);
  }

  .admin-product-placeholder {
    display: grid;
    place-items: center;
  }

  .admin-product-placeholder svg,
  .admin-empty svg {
    width: 66px;
    height: 66px;
    fill: none;
    stroke: rgba(255, 255, 255, 0.38);
    stroke-width: 1.4;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .stock-pill {
    position: absolute;
    right: 0.85rem;
    bottom: 0.85rem;
    padding: 0.42rem 0.65rem;
    border: 1px solid currentColor;
    border-radius: 999px;
    background: rgba(7, 8, 13, 0.80);
    color: var(--green);
    font-size: 0.75rem;
    font-weight: 900;
    backdrop-filter: blur(8px);
  }

  .stock-pill.is-out {
    color: var(--red);
  }

  .admin-product-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    padding: 1.05rem;
  }

  .admin-product-category {
    margin-bottom: 0.5rem;
    color: var(--cyan);
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .admin-product-body h3 {
    min-height: 2.4em;
    margin-bottom: 0.55rem;
  }

  .admin-product-description {
    display: -webkit-box;
    overflow: hidden;
    min-height: 3.9em;
    color: var(--text-muted);
    font-size: 0.92rem;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .admin-product-bottom {
    margin-top: auto;
    padding-top: 0.95rem;
  }

  .admin-product-bottom strong {
    color: var(--text);
    font-size: 1.35rem;
    font-weight: 950;
  }

  .admin-product-actions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.55rem;
    margin-top: 0.8rem;
  }

  .action-btn {
    width: 100%;
    min-height: 38px;
    padding: 0.52rem 0.55rem;
    font-size: 0.84rem;
  }

  .action-btn.secondary:hover {
    border-color: var(--cyan);
    box-shadow: 0 0 0 1px rgba(0, 212, 255, 0.34), 0 0 18px rgba(0, 212, 255, 0.18);
  }

  .action-btn.danger:hover {
    border-color: var(--red);
    box-shadow: 0 0 0 1px rgba(255, 92, 122, 0.34), 0 0 18px rgba(255, 92, 122, 0.18);
  }

  .loading-skeleton {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.1rem;
  }

  .skeleton-card {
    height: 430px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: linear-gradient(90deg, rgba(255, 255, 255, 0.035) 25%, rgba(255, 255, 255, 0.095) 50%, rgba(255, 255, 255, 0.035) 75%);
    background-size: 200% 100%;
    animation: skeleton-shimmer 1.35s infinite;
  }

  @keyframes skeleton-shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  @media (max-width: 760px) {
    .page-hero,
    .toolbar {
      align-items: stretch;
      flex-direction: column;
    }

    .add-btn {
      width: 100%;
    }

    .toolbar-stat {
      border-right: 0;
      border-bottom: 1px solid var(--line);
      padding-right: 0;
      padding-bottom: 0.8rem;
    }

    .products-grid-admin {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 420px) {
    .products-grid-admin {
      grid-template-columns: 1fr;
    }

    .admin-product-card {
      min-height: 0;
    }

    .admin-product-actions {
      grid-template-columns: 1fr;
    }
  }
</style>
